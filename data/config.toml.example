[plex]
base_url = ""
token = ""
timeout = 30

[scoring]
min_width = 300
min_height = 450
preferred_aspect_ratio = 0.6667
aspect_ratio_tolerance = 0.15
prefer_provider_posters = true
provider_priority = ["tmdb", "tvdb", "gracenote", "local", "upload"]
resolution_weight = 1.0
aspect_ratio_weight = 1.5
provider_weight = 1.0
penalize_landscape = true
landscape_penalty = -5.0
# Broken-poster detection (inspects the current poster's actual pixels)
broken_aspect_tolerance = 0.25
# Improve mode (opt-in): also suggest a better poster for items whose current
# poster came from a Plex agent (gracenote/local/embedded), using TMDB's top
# community-voted poster. Curated/uploaded and tmdb/tvdb posters are left
# alone. Off by default; adds a per-item TMDB lookup (slower).
improve_posters = false

[tmdb]
# Get a free API key (v3 auth) at https://www.themoviedb.org/settings/api
# Stored encrypted at runtime; leave blank to disable TMDB poster lookup.
api_key = ""
enabled = true
language = "en"
preview_size = "w342"

[app]
host = "0.0.0.0"
port = 8888
dry_run = true
skip_locked = true
force_replace = false
log_level = "INFO"
open_browser = true
whitelisted_libraries = []
blacklisted_libraries = []
